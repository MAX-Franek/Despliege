pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - /busybox/cat
    tty: true
    volumeMounts:
    - name: docker-config
      mountPath: /kaniko/.docker
  volumes:
  - name: docker-config
    secret:
      secretName: dockerhub-secret
"""
        }
    }

    environment {
        IMAGE = "franparradaw/ptaller-webserver" 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Push Image'){
            steps {
                container('kaniko'){
                    sh """
                    /kaniko/executor \
                        --context `pwd` \
                        --dockerfile deploy/build_img/Dockerfile \
                        --destination ${IMAGE}:${GIT_COMMIT} \
                        --destination ${IMAGE}:latest \
                        --snapshot-mode=redo \
                        --single-snapshot
                    """
                }
            }
        }
        stage('Update Helm Chart & Push to Git') {
            steps {
                script {
                    // Cambiar el tag en el values.yaml usando sed
                    sh "sed -i 's/tag: .*/tag: \"${GIT_COMMIT}\"/' deploy/miporfolio/values.yaml"
            
                    // Configurar Git y subir los cambios
                    sh """
                    git config user.name "Jenkins CI"
                    git config user.email "[EMAIL_ADDRESS]"
                    git add deploy/miporfolio/values.yaml
                    git commit -m "Update image tag to ${GIT_COMMIT} [skip ci]"
                    git push origin mainp
                    """
                }
            }
        }
    }
}