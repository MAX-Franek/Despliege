pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - /busybox/cat
    tty: true
    volumeMounts:
    - name: docker-config
      mountPath: /kaniko/.docker
  volumes:
  - name: docker-config
    secret:
      secretName: dockerhub-secret
"""
        }
    }

    environment {
        // Asegúrate de que este nombre sea correcto para tu Docker Hub
        IMAGE = "franparradaw/ptaller-webserver" 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Push Image'){
            steps {
                container('kaniko'){
                    sh """
                    /kaniko/executor \
                        --context `pwd` \
                        --dockerfile deploy/build_img/Dockerfile \
                        --destination ${IMAGE}:${GIT_COMMIT} \
                        --destination ${IMAGE}:latest \
                        --snapshot-node=redo \
                        --single-snapshot
                    """
                }
            }
        }
    }
}