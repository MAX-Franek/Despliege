pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - /busybox/cat
    tty: true
    volumeMounts:
    - name: docker-config
      mountPath: /kaniko/.docker
  volumes:
  - name: docker-config
    secret:
      secretName: dockerhub-secret
"""
        }
    }

    environment {
        IMAGE = "franparradaw/ptaller-webserver" 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Push Image'){
            steps {
                container('kaniko'){
                    sh """
                    /kaniko/executor \
                        --context `pwd` \
                        --dockerfile deploy/build_img/Dockerfile \
                        --destination ${IMAGE}:${GIT_COMMIT} \
                        --destination ${IMAGE}:latest \
                        --snapshot-mode=redo \
                        --single-snapshot
                    """
                }
            }
        }
stage('Update Helm Chart & Push to Git') {
            steps {
                script {
                    // 1. Nos aseguramos de estar en la rama correcta ANTES de editar nada
                    // Cambia 'main' por 'prod' si esa es tu rama de producción real.
                    sh """
                        git checkout main
                        git pull origin main
                    """

                    // 2. Cambiamos el tag en el values.yaml
                    sh "sed -i 's/tag: .*/tag: \"${GIT_COMMIT}\"/' deploy/miporfolio/values.yaml"
            
                    // 3. Configuramos Git, hacemos el commit y usamos credenciales para subir
                    // Aquí usamos withCredentials para que Jenkins inyecte tu token de GitHub
                    withCredentials([usernamePassword(credentialsId: 'fran', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                        sh """
                            git config user.name "Jenkins CI"
                            git config user.email "jenkins@tuservidor.com"
                            git add deploy/miporfolio/values.yaml
                            git commit -m "Update image tag to ${GIT_COMMIT} [skip ci]"
                            
                            # Subimos el cambio usando el token para autenticarnos
                            git push https://${GIT_USER}:${GIT_PASS}@github.com/MAX-Franek/Despliege.git HEAD:prod
                        """
                    }
                }
            }
        }
    }
}